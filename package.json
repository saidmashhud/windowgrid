{
  "name": "windowgrid",
  "version": "0.1.0",
  "description": "Headless, framework-agnostic virtualized data-grid core capable of smoothly rendering millions of rows with dynamic heights, powered by a Fenwick tree for O(log n) offset math.",
  "type": "module",
  "license": "MIT",
  "author": "windowgrid contributors",
  "keywords": [
    "virtualization",
    "windowing",
    "data-grid",
    "fenwick-tree",
    "binary-indexed-tree",
    "performance",
    "headless",
    "react"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "bench": "tsx bench/offset.bench.ts"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
