{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "paths": {
      "windowgrid/react": ["../src/react/index.ts"],
      "windowgrid/core": ["../src/core/index.ts"],
      "windowgrid": ["../src/core/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
